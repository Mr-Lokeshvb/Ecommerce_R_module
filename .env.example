# Local development example. Do not put real secrets in GitHub.
VITE_API_URL=http://localhost:5000

# Backend
NODE_ENV=development
PORT=5000
JWT_SECRET=replace-with-a-long-random-secret
MONGODB_URI=mongodb://localhost:27017/mern-ecommerce
CLIENT_URL=http://localhost:5173

# Optional payment/config values
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email SMTP. Defaults below work for Outlook/Microsoft 365.
EMAIL_SYSTEM_DISABLED=false
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your-outlook-email@example.com
EMAIL_PASS=your-outlook-password-or-app-password
EMAIL_FROM=Fashion Era <your-outlook-email@example.com>
